# Discord bot token — Developer Portal → your app → Bot → Reset Token
DISCORD_TOKEN=

# Channel to post alerts in. Enable Developer Mode (Settings → Advanced),
# then right-click the channel → Copy Channel ID.
DISCORD_CHANNEL_ID=

# Your server (guild) ID — right-click the server icon → Copy Server ID.
# Recommended: makes slash commands appear instantly instead of up to ~1 hour.
DISCORD_GUILD_ID=

# Optional: Best Buy Products API key (developer.bestbuy.com). Required for the
# `bestbuy` source; leave blank if you only use Generic URL watches.
BESTBUY_API_KEY=

# Optional: hours between automatic checks (default: 1). Keep it reasonable.
CHECK_INTERVAL_HOURS=1

# Optional: where the watchlist is stored (default: watchlist.json)
# WATCHLIST_PATH=watchlist.json
